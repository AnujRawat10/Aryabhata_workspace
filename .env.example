# Postgres connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/article_review?schema=public"

# NextAuth - generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-32-byte-base64-string"
# Must match the port the app runs on. `npm run dev` uses port 3002.
NEXTAUTH_URL="http://localhost:3002"
